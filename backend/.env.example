# Copy this file to .env for local (non-Docker) development.
# In Docker, these are supplied via docker-compose.yml / your orchestrator instead.

ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false

# --- Security ---
# Generate a real secret with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- Database ---
DATABASE_URL=postgresql+psycopg2://findadvisor:findadvisor@localhost:5432/findadvisor

# --- Groq (free tier, no credit card, no billing/prepay system) - used for chat only ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# --- Embeddings: run locally via fastembed, no API key/quota/billing ever ---
# First run downloads the model (~500MB) from HuggingFace/GCS and caches it -
# leave FASTEMBED_CACHE_PATH blank to use fastembed's own default cache dir.
FASTEMBED_MODEL_NAME=BAAI/bge-base-en-v1.5
FASTEMBED_CACHE_PATH=

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Observability ---
# Leave blank to log traces to console; point at an OTel collector/Jaeger/Tempo endpoint otherwise.
OTEL_EXPORTER_OTLP_ENDPOINT=
ENABLE_PROMETHEUS=true
